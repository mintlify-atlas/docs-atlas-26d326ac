  "keyFeatures": [
    "Human-in-the-loop chunk review and editing before publishing",
    "Multi-source ingestion: web URLs, file uploads (PDF, DOCX), and manual text",
    "Draft session workflow: ingest → review → preview → publish",
    "AI-powered chunking, embeddings, and enrichment via OpenAI",
    "Qdrant vector database for published knowledge storage",
    "Built-in MCP server for IDE integration (Cursor, VS Code)",
    "RAG-powered chat playground with citations",
    "AI collection agent for chunk generation and collection cleaning",
    "Configurable chunking parameters per ingestion",
    "Feature flags for toggling web ingest, file ingest, and AI agent"
  ],
  "publicApiSurface": [
    "GET /api/collections — list all collections",
    "POST /api/collections — create a collection",
    "GET /api/collections/:id — get collection details",
    "DELETE /api/collections/:id — delete collection",
    "GET/POST /api/collections/:id/chunks — manage collection chunks",
    "POST /api/collections/:collectionId/chat — RAG-powered chat",
    "POST /api/ingest/web — ingest from web URL",
    "POST /api/ingest/manual — ingest from manual text",
    "POST /api/ingest/file — ingest from file upload",
    "GET /api/session — list all sessions",
    "GET /api/session/:id — get session details",
    "POST /api/session/:id/chunks — generate chunks via LLM",
    "POST /api/session/:id/chunks/merge — merge chunks",
    "POST /api/session/:id/chunks/:chunkId/split — split chunk",
    "PATCH /api/session/:id/chunks/:chunkId — update chunk text",
    "POST /api/session/:id/preview — lock and validate session",
    "POST /api/session/:id/publish — publish chunks to collection",
    "DELETE /api/session/:id — delete session",
    "POST /api/search — vector similarity search",
    "GET /api/health/liveness — liveness check",
    "GET /api/health/readiness — readiness check (Redis + Qdrant)",
    "POST /mcp — MCP Streamable HTTP endpoint",
    "GET /sse + POST /messages — MCP legacy SSE endpoint"
  ]
}
